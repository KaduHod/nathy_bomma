<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <%- include('partials/head', { title: title }) %>
</head>
<body>
    <main class="main main-solo">
        <header class="topbar">
            <div style="min-width:0;">
                <div class="eyebrow">Administrador</div>
                <h1><%= projetoId ? "Editar Projeto" : "Novo Projeto" %></h1>
                <p class="view-intro">Frequência sempre mensal — um projeto por cliente por mês.</p>
            </div>
            <div class="topbar-meta">
                <a href="/" class="btn-ghost">← Voltar ao dashboard</a>
            </div>
        </header>

        <div id="loading" class="state" <% if (!projetoId) { %>hidden<% } %>>
            <div class="spin"></div>Carregando projeto…
        </div>
        <div id="error" class="state--error" hidden></div>

        <section id="content" <% if (projetoId) { %>hidden<% } %>>
            <div class="panel">
                <div class="panel-head">
                    <span class="panel-title"><%= projetoId ? "Editar projeto" : "Dados do projeto" %></span>
                    <span class="panel-sub">Campos com * são obrigatórios</span>
                </div>

                <form id="form">
                    <input type="hidden" id="fId" value="<%= projetoId ?? '' %>" />

                    <div class="two-col">
                        <div class="form-group">
                            <label for="fNome">Nome do projeto *</label>
                            <input type="text" id="fNome" required />
                        </div>
                        <div class="form-group">
                            <label for="fCliente">Cliente *</label>
                            <select id="fCliente" required>
                                <option value="">Carregando clientes…</option>
                            </select>
                        </div>
                    </div>

                    <div class="two-col">
                        <div class="form-group">
                            <label for="fStatus">Status *</label>
                            <select id="fStatus" required>
                                <option value="">Selecione…</option>
                                <% status.forEach(function(s) { %>
                                <option value="<%= s.id %>"><%= s.nome %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="fEtapa">Etapa</label>
                            <input type="text" id="fEtapa" placeholder="Ex: Produção, Aprovação…" />
                        </div>
                    </div>

                    <div class="two-col">
                        <div class="form-group">
                            <label for="fCategoria">Categoria</label>
                            <select id="fCategoria">
                                <option value="">Selecione…</option>
                                <option value="Design">Design</option>
                                <option value="Audiovisual">Audiovisual</option>
                                <option value="Planejamento e Design">Planejamento e Design</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="fEstimativa">Estimativa (horas)</label>
                            <input type="number" id="fEstimativa" step="0.25" min="0" placeholder="Ex: 8.5" />
                        </div>
                    </div>

                    <div class="two-col">
                        <div class="form-group">
                            <label for="fDataInicio">Data de início</label>
                            <input type="date" id="fDataInicio" />
                        </div>
                        <div class="form-group">
                            <label for="fDataVencimento">Data de vencimento *</label>
                            <input type="date" id="fDataVencimento" required />
                        </div>
                    </div>

                    <div class="form-group" style="max-width:calc(50% - 8px);">
                        <label for="fDataConclusao">Data de conclusão</label>
                        <input type="date" id="fDataConclusao" />
                    </div>

                    <div class="form-error" id="formError"></div>

                    <div class="modal-actions" style="margin-top:22px;">
                        <a href="/" class="btn-ghost">Cancelar</a>
                        <button type="submit" class="btn-primary" id="btnSalvar">
                            <%= projetoId ? "Salvar alterações" : "Criar projeto" %>
                        </button>
                    </div>
                </form>
            </div>
        </section>
    </main>

    <div class="toast" id="toast"></div>

    <script src="/projeto-form.js"></script>
</body>
</html>
